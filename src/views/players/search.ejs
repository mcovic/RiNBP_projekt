<%- include("../partials/header") %>

<form method="GET" action="/players/search" class="search-form">
  <fieldset>
    <legend>Position ($in)</legend>
    <% positions.forEach(function (pos) { %>
      <label class="inline">
        <input type="checkbox" name="position" value="<%= pos %>"
          <%= selected.positions.includes(pos) ? "checked" : "" %> />
        <%= pos %>
      </label>
    <% }); %>
  </fieldset>

  <label>Max price ($lt)
    <input type="number" step="0.1" name="maxPrice" value="<%= selected.maxPrice %>" placeholder="e.g. 9" />
  </label>

  <label>Name contains ($regex, case-insensitive)
    <input type="text" name="name" value="<%= selected.name %>" placeholder="e.g. mar" />
  </label>

  <label>Sort by
    <select name="sort">
      <option value="totalPoints" <%= selected.sort === "totalPoints" ? "selected" : "" %>>Total points (desc)</option>
      <option value="price" <%= selected.sort === "price" ? "selected" : "" %>>Price (desc)</option>
      <option value="name" <%= selected.sort === "name" ? "selected" : "" %>>Name (asc)</option>
    </select>
  </label>

  <div class="form-actions">
    <button type="submit">Search</button>
    <a class="btn-outline" href="/players/search">Reset</a>
  </div>
</form>

<!-- Index-usage hint with a tooltip explaining the explain() summary. -->
<p class="explain">
  <% if (explain.usedIndex) { %>
    <span class="badge ok tip" tabindex="0" data-tip="The query used the index '<%= explain.indexName %>'. Plan stages: <%= explain.stages %>. MongoDB scanned <%= explain.totalKeysExamined %> index keys and examined <%= explain.totalDocsExamined %> documents to return <%= explain.nReturned %>. An IXSCAN means it jumped straight to matching entries instead of reading the whole collection.">
      ✓ index used: <%= explain.indexName %>
    </span>
  <% } else { %>
    <span class="badge warn tip" tabindex="0" data-tip="No index backed this query — a COLLSCAN read the whole collection (<%= explain.totalDocsExamined %> docs examined for <%= explain.nReturned %> returned). Regex / name-only filters can't use the {position:1, price:-1} index; add a position or price filter to see an IXSCAN.">
      ⚠ collection scan (no index)
    </span>
  <% } %>
  <span class="hint">stages: <%= explain.stages %> · examined <%= explain.totalDocsExamined %> docs → <%= explain.nReturned %> returned <em>(hover for details)</em></span>
</p>

<table>
  <thead>
    <tr><th>Name</th><th>Pos</th><th>Club</th><th>Price</th><th>Points</th></tr>
  </thead>
  <tbody>
    <% if (results.length === 0) { %>
      <tr><td colspan="5">No players match these filters.</td></tr>
    <% } %>
    <% results.forEach(function (p) { %>
      <tr>
        <td><%= p.name %></td>
        <td><%= p.position %></td>
        <td><%= p.club %></td>
        <td><%= p.price %></td>
        <td><%= p.totalPoints %></td>
      </tr>
    <% }); %>
  </tbody>
</table>

<div class="pagination">
  <span><%= total %> result(s) — page <%= page %> / <%= totalPages %></span>
  <% if (page > 1) { %>
    <a href="/players/search?<%= baseQs %>&page=<%= page - 1 %>">&larr; Prev</a>
  <% } %>
  <% if (page < totalPages) { %>
    <a href="/players/search?<%= baseQs %>&page=<%= page + 1 %>">Next &rarr;</a>
  <% } %>
</div>

<%- include("../partials/footer") %>
