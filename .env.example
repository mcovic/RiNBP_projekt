# MongoDB connection string.
# Local development (standalone mongod):
MONGODB_URI=mongodb://127.0.0.1:27017
# Demo/seminar (Atlas, replica set, required for transactions):
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database name (kept fixed per project convention).
DB_NAME=fantasy_league

# Express HTTP port.
PORT=3000
